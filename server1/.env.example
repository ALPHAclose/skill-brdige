NODE_ENV=development
PORT=5001

DATABASE_URL=postgresql://auth_user:auth_secret_password@localhost:5432/db_auth?schema=public
REDIS_URL=redis://:skillbridge_redis_secret@localhost:6379/0

JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
LOG_FORMAT=dev

TRUSTED_GATEWAY_HEADER=x-skillbridge-gateway
TRUSTED_GATEWAY_SECRET=change_this_internal_gateway_secret
