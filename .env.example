# SkillBridge root environment variables
# Copy this file to .env for local Docker Compose development.

# Public ports
FRONTEND_PORT=3000
GATEWAY_PORT=4000
SERVER1_PORT=5001
SERVER2_PORT=5002
REDIS_PORT=6379
POSTGRES_AUTH_PORT=5432
POSTGRES_COURSES_PORT=5433

# Public URLs used by browser-facing code
FRONTEND_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Redis
REDIS_PASSWORD=skillbridge_redis_secret

# PostgreSQL Auth DB for Server1
POSTGRES_AUTH_DB=db_auth
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_secret_password

# PostgreSQL Courses DB for Server2
POSTGRES_COURSES_DB=db_courses
POSTGRES_COURSES_USER=courses_user
POSTGRES_COURSES_PASSWORD=courses_secret_password

# JWT and refresh-token settings
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# API Gateway
GATEWAY_RATE_LIMIT_WINDOW_MS=900000
GATEWAY_RATE_LIMIT_MAX=100
GATEWAY_LOG_FORMAT=dev

# Server1
SERVER1_LOG_FORMAT=dev

# Internal gateway trust header used with X-User-* forwarded identity headers
TRUSTED_GATEWAY_HEADER=x-skillbridge-gateway
TRUSTED_GATEWAY_SECRET=change_this_internal_gateway_secret
